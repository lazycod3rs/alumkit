parameters:
    level: 7
    paths:
        - src
        - config
        - database
        - routes
    tmpDir: build/phpstan
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            message: '~expects view-string\|null, string given~'
            paths:
                - src/AlumkitServiceProvider.php
                - src/Http/Controllers/*.php
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/*.php
